<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div style="text-align:center;margin-bottom:24px;font-size:40px">🐻</div>
    <h1 class="auth-title">البيت الروسي</h1>
    <p class="auth-sub">سجّل دخولك أو أنشئ حساباً جديداً</p>

    <% if (error) { %>
      <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✅ <%= success %></div>
    <% } %>

    <!-- Tabs -->
    <div class="tabs">
      <button class="tab <%= typeof activeTab !== 'undefined' && activeTab === 'signup' ? '' : 'active' %>" data-tab="signin">تسجيل الدخول</button>
      <button class="tab <%= typeof activeTab !== 'undefined' && activeTab === 'signup' ? 'active' : '' %>" data-tab="signup">حساب جديد</button>
    </div>

    <!-- Sign In Form -->
    <div id="form-signin" class="auth-form" style="display: <%= typeof activeTab !== 'undefined' && activeTab === 'signup' ? 'none' : 'block' %>">
      <form method="POST" action="/auth/signin">
        <div class="form-group">
          <label class="form-label">البريد الإلكتروني</label>
          <input type="email" name="email" class="form-input" placeholder="example@email.com" required>
        </div>
        <div class="form-group">
          <label class="form-label">كلمة المرور</label>
          <input type="password" name="password" class="form-input" placeholder="••••••" required>
        </div>
        <button type="submit" class="btn-submit">تسجيل الدخول →</button>
      </form>
    </div>

    <!-- Sign Up Form -->
    <div id="form-signup" class="auth-form" style="display: <%= typeof activeTab !== 'undefined' && activeTab === 'signup' ? 'block' : 'none' %>">
      <form method="POST" action="/auth/signup">
        <div class="form-group">
          <label class="form-label">الاسم الكامل</label>
          <input type="text" name="name" class="form-input" placeholder="محمد أحمد" required>
        </div>
        <div class="form-group">
          <label class="form-label">البريد الإلكتروني</label>
          <input type="email" name="email" class="form-input" placeholder="example@email.com" required>
        </div>
        <div class="form-group">
          <label class="form-label">رقم الهاتف</label>
          <input type="tel" name="phone" class="form-input" placeholder="+966 5xxxxxxxx">
        </div>
        <div class="form-group">
          <label class="form-label">كلمة المرور (6 أحرف على الأقل)</label>
          <input type="password" name="password" class="form-input" placeholder="••••••" required minlength="6">
        </div>
        <button type="submit" class="btn-submit">إنشاء الحساب →</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
