<!-- Hero -->

<section class="hero">
  <div class="hero-card">
    <div class="hero-content">
      <span class="hero-badge">⭐ عروض نهاية الأسبوع</span>
      <h1 class="hero-title">
        أفضل المنتجات<br>
        الروسية <span>الأصيلة</span><br>
        لبيتك
      </h1>
      <p class="hero-sub">نجلب لك أجود المنتجات الروسية مباشرة من المصنع — شوكولاتة، شاي، فراء، سكاكين وأكثر. توصيل سريع للسعودية والإمارات وجميع الدول العربية.</p>
      <div class="hero-btns">
        <a href="#products" class="btn-primary">تسوق الآن ←</a>
        <a href="#products" class="btn-secondary">اكتشف العروض</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="stat-val">⭐ 4.9</span><span class="stat-label">تقييم العملاء</span></div>
        <div class="stat"><span class="stat-val">17+</span><span class="stat-label">دولة توصيل</span></div>
        <div class="stat"><span class="stat-val">5000+</span><span class="stat-label">طلب ناجح</span></div>
      </div>
    </div>
    <div class="hero-bear">🐻</div>
  </div>
</section>

